#!/bin/bash
# ---
# name: {{.Name}}
# description: {{.Description}}
{{- if .Category}}
# category: {{.Category}}
{{- end}}
{{- if .Parameters}}
# parameters:
{{- range .Parameters}}
#   - name: {{.Name}}
#     type: {{.Type}}
{{- if .Required}}
#     required: true
{{- end}}
{{- if .Default}}
#     default: {{.Default}}
{{- end}}
{{- if .Description}}
#     description: {{.Description}}
{{- end}}
{{- end}}
{{- end}}
# ---

set -euo pipefail

{{- if .ParamData}}

# Parameters (provided via TAP_PARAM_* env vars when run through tap)
{{- range .ParamData}}
{{- if .Default}}
{{.VarName}}="${{printf "{%s:-%s}" .EnvVar .Default}}"
{{- else}}
{{.VarName}}="${{printf "{%s:-}" .EnvVar}}"
{{- end}}
{{- end}}
{{- range .ParamData}}
{{- if and .Required (not .Default)}}

if [[ -z "${{.VarName}}" ]]; then
    echo "Error: {{.Name}} is required" >&2
    exit 1
fi
{{- end}}
{{- end}}
{{- end}}

main() {
    echo "Running {{.Name}}"

    # Your implementation here
}

main "$@"
